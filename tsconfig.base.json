{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@teddy/backend/*": [
        "back-end/src/*"
      ],
      "@teddy/frontend/*": [
        "front-end/src/*"
      ]
    }
  }
}

